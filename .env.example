# ===========================================
# Docker 部署环境变量示例
# 复制此文件为 .env 后按需修改
# 命令: copy .env.example .env  (Windows) 或 cp .env.example .env  (Linux/Mac)
# ===========================================

# 前端访问端口（宿主机映射端口，如 80 或 8080）
FRONTEND_PORT=8080

# Django 配置
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=*

# MySQL 数据库配置（Docker 部署使用）
DB_NAME=iot_platform
DB_USER=root
DB_PASSWORD=your_mysql_password
# 宿主机映射端口（若本机 3306 被占用，改为 3307 等）
MYSQL_HOST_PORT=3307

# MQTT/EMQX 配置（Docker 容器需能访问到 EMQX）
# EMQX 在本机：MQTT_BROKER=host.docker.internal
# EMQX 在远程：MQTT_BROKER=实际IP或域名
# MQTT_BROKER=host.docker.internal
# MQTT_PORT=1883
# MQTT_USERNAME=your_mqtt_username
# MQTT_PASSWORD=your_mqtt_password
