# ===========================================
# 启动必备环境变量（仅进程级配置，复制为 .env 后修改）
# 业务配置（MQTT broker、离线超时、数据保留等）已迁移到 PlatformConfig 表，
# 通过 `python manage.py configure` 维护，不再写在这里。
# ===========================================

# ---- Django 必备 ----
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=*

# ---- MySQL 必备（Docker 部署）----
DB_NAME=iot_platform
DB_USER=root
DB_PASSWORD=your_mysql_password

# ---- 端口（Docker 宿主机暴露）----
MYSQL_HOST_PORT=3307
# 前端访问端口：选用五位高端口避开 8080 等常见冲突
FRONTEND_PORT=48080
# Django Admin 直连端口（仅管理员/排错用）
ADMIN_PORT=48081

# ---- 非 Docker 部署且使用 MySQL 时取消注释 ----
# DB_USE_MYSQL=true
# DB_HOST=localhost
# DB_PORT=3306
