# ===========================================
# 启动必备环境变量（仅保留服务器启动必需项）
# 复制为 .env 后修改
# 其他配置（数据留存、设备离线等）在 platform_settings/default_config.json
# ===========================================

# 前端与 Admin 端口（Docker）
FRONTEND_PORT=8080
ADMIN_PORT=8081

# Django 必备
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=*

# MySQL 必备（Docker 部署）
DB_NAME=iot_platform
DB_USER=root
DB_PASSWORD=your_mysql_password
MYSQL_HOST_PORT=3307

# MQTT 连接必备（seed 会写入 platform_settings，供运行时使用）
MQTT_BROKER=116.62.68.29
MQTT_PORT=1883
# MQTT_USERNAME=
# MQTT_PASSWORD=
