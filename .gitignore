# ===== 项目根目录 .gitignore =====

# Python 虚拟环境 (所有位置)
.venv/
venv/
ENV/
env/
platform/.venv/

# Node
node_modules/

# 环境变量
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# 操作系统
.DS_Store
Thumbs.db

# 日志和临时文件
*.log
*.log.*
*.tmp
*.temp

# IoT 平台日志目录
iot_control_platform/logs/

# 自动化迁移（不追踪，由 makemigrations 生成）
iot_control_platform/automation/migrations/
