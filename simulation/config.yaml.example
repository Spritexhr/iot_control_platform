# Broker 连接配置模板 —— 复制为 config.yaml 后再按需修改
#   cp config.yaml.example config.yaml
#
# 节点列表不在这里，请到 simulation/manifests/*.yaml 编辑/新增清单，
# 用 `python run.py --manifest <name>` 选择启动哪一份（可重复）。

broker:
  host: 127.0.0.1          # 改成你的 EMQX 地址
  port: 1883
  username: ""             # broker 级默认账号，留空表示匿名
  password: ""             # 节点级也可以在 manifest 里单独覆盖
