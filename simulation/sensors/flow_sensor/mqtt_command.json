{
    "turn_on": {
        "mqtt_message": {"command": "enable"},
        "description": "启动传感器",
        "params": []
    },
    "turn_off": {
        "mqtt_message": {"command": "disable"},
        "description": "关闭传感器",
        "params": []
    },
    "set_data_interval": {
        "mqtt_message": {"command": "set_data_interval", "interval": "{val}"},
        "description": "设置数据上报间隔（秒，10-3600）",
        "params": ["val"]
    },
    "set_status_interval": {
        "mqtt_message": {"command": "set_status_interval", "interval": "{val}"},
        "description": "设置状态上报间隔（秒，30-600）",
        "params": ["val"]
    },
    "reset_volume": {
        "mqtt_message": {"command": "reset_volume"},
        "description": "清零累计体积（L），适合按批次/班次重置统计",
        "params": []
    }
}
